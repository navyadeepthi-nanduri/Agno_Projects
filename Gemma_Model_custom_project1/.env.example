# ==========================================
# Gemma Multimodal Chatbot - Environment File
# ==========================================

# --------------------------
# App Settings
# --------------------------
APP_TITLE=Gemma Multimodal Chatbot API
DEBUG=true

# --------------------------
# OpenRouter (Main LLM)
# --------------------------
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter chat completions endpoint
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# Main model (Vision-capable Gemma model for text + image support)
MODEL_NAME=google/gemma-3-12b-it

# Optional but recommended OpenRouter headers
HTTP_REFERER=http://localhost:7860
X_TITLE=Gemma Multimodal Chatbot

# --------------------------
# Groq (Speech-to-Text)
# --------------------------
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Recommended Whisper model for transcription
GROQ_STT_MODEL=whisper-large-v3-turbo

# --------------------------
# Request / Timeout Settings
# --------------------------
REQUEST_TIMEOUT=60